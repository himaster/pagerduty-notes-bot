PD_API_TOKEN=your-pagerduty-api-token
PD_FROM_EMAIL=your-pd-user@example.com
PD_WEBHOOK_SECRET=secret1,secret2
# optional: enables Slack user-group mentions when an alert has a `slack-team` label
# Bot token needs the `usergroups:read` scope.
SLACK_BOT_TOKEN=
TRAEFIK_HOST=pd-notes.example.com
IMAGE=pagerduty-notes-bot:latest
